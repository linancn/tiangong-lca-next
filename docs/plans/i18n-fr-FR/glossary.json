  "terms": [
    {
      "concept": "life cycle assessment",
      "preferred": ["analyse du cycle de vie", "évaluation du cycle de vie", "ACV"],
      "forbidden": ["évaluation du cercle de vie"]
    },
    {
      "concept": "process",
      "preferred": ["processus", "processus élémentaire"],
      "conditional": ["procédé"],
      "note": "Use processus for the TIDAS/LCA data object and graph node; qualify with élémentaire only where the source context does. Use procédé only for a physical manufacturing or treatment operation, never merely as a synonym for the dataset object."
    },
    {
      "concept": "flow",
      "preferred": ["flux"],
      "note": "Preserve the LCA/TIDAS object distinction from flow property and exchange."
    },
    {
      "concept": "flow property",
      "preferred": ["propriété de flux"]
    },
    {
      "concept": "unit group",
      "preferred": ["groupe d’unités", "groupe d'unités"]
    },
    {
      "concept": "review",
      "preferred": ["revue", "revue critique"],
      "conditional": ["révision", "examen"],
      "note": "Use revue for the product peer-review workflow and revue critique for the established ACV concept. Use révision for editing or revising content/version state, and examen only for a literal inspection action."
    },
    {
      "concept": "dataset",
      "preferred": ["jeu de données", "données"],
      "forbidden": ["ensemble de data"]
    },
    {
      "concept": "carbon footprint",
      "preferred": ["empreinte carbone"]
    },
    {
      "concept": "allocation",
      "preferred": ["allocation"],
      "note": "Keep the established LCA technical term; do not substitute affectation when describing allocation methods."
    },
    {
      "concept": "TIDAS",
      "preferred": ["TIDAS"],
      "note": "Never translate product names, schema names, IDs, hashes, MIME types, or file extensions. Keep LCA/LCIA only where they are part of such a fixed name or raw token; use ACV/ÉICV in ordinary French product prose."
    }
  ]
}
