FROM rust:1.93-bookworm

ARG LCA_WORKER_REPO=https://github.com/linancn/tiangong-lca-worker.git
ARG LCA_WORKER_REF=refs/heads/main
ARG LCA_CALCULATOR_REPO=
ARG LCA_CALCULATOR_REF=
ARG TIDAS_TOOLS_REPO=https://github.com/tiangong-lca/tidas-tools.git
ARG TIDAS_TOOLS_REF=main

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git \
        libsuitesparse-dev \
        libopenblas-dev \
        liblapack-dev \
        pkg-config \
        cmake \
        python3 \
        python3-venv \
        ca-certificates \
    && python3 -m venv /opt/tidas-tools-venv \
    && /opt/tidas-tools-venv/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/tidas-tools-venv/bin/pip install --no-cache-dir "git+${TIDAS_TOOLS_REPO}@${TIDAS_TOOLS_REF}" \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/opt/tidas-tools-venv/bin:${PATH}"

WORKDIR /workspace/tiangong-lca-worker

RUN cat <<'EOF' >/usr/local/bin/worker-entrypoint
#!/usr/bin/env bash
set -euo pipefail

solver_bin="/workspace/tiangong-lca-worker/target/release/solver-worker"
package_bin="/workspace/tiangong-lca-worker/target/release/package_worker"

package_args=()
if [[ -n "${PACKAGE_PGMQ_QUEUE:-}" ]]; then
  package_args+=(--pgmq-queue "${PACKAGE_PGMQ_QUEUE}")
fi
if [[ -n "${PACKAGE_WORKER_VT_SECONDS:-}" ]]; then
  package_args+=(--worker-vt-seconds "${PACKAGE_WORKER_VT_SECONDS}")
fi
if [[ -n "${PACKAGE_WORKER_POLL_MS:-}" ]]; then
  package_args+=(--worker-poll-ms "${PACKAGE_WORKER_POLL_MS}")
fi

terminate_children() {
  for pid in "${solver_pid:-}" "${package_pid:-}"; do
    if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
      kill "${pid}" 2>/dev/null || true
    fi
  done
}

cleanup() {
  local status=$?
  trap - EXIT INT TERM
  terminate_children
  wait || true
  exit "${status}"
}

trap 'exit 0' INT TERM
trap cleanup EXIT

"${solver_bin}" &
solver_pid=$!

"${package_bin}" "${package_args[@]}" &
package_pid=$!

wait -n "${solver_pid}" "${package_pid}"
EOF
RUN chmod +x /usr/local/bin/worker-entrypoint

RUN git init . \
    && worker_repo="${LCA_CALCULATOR_REPO:-${LCA_WORKER_REPO}}" \
    && worker_ref="${LCA_CALCULATOR_REF:-${LCA_WORKER_REF}}" \
    && git remote add origin "${worker_repo}" \
    && git fetch --depth 1 origin "${worker_ref}" \
    && git checkout --detach FETCH_HEAD

RUN cargo build -p solver-worker --bin solver-worker --bin snapshot_builder --bin package_worker --release

ENTRYPOINT ["/usr/local/bin/worker-entrypoint"]
