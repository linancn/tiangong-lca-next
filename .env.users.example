# Contact and team smoke-test credentials
#
# Usage:
#   cp .env.users.example .env.users.local
#   the smoke scripts will auto-load .env.users.local when it exists
#   optional: set -a && source .env.users.local && set +a
#
# The smoke scripts support two credential styles:
# 1. TEST_USERS_JSON
# 2. TEST_<ROLE>_EMAIL / TEST_<ROLE>_PASSWORD
#
# If both are present for the same role, the direct role-specific variables win.
# Keep only the roles you actually use.

# Option A: provide all roles in one JSON blob.
TEST_USERS_JSON='{
  "user": {
    "email": "user@example.com",
    "password": "replace-with-user-password"
  },
  "admin": {
    "email": "admin@example.com",
    "password": "replace-with-admin-password"
  },
  "team-owner": {
    "email": "team-owner@example.com",
    "password": "replace-with-team-owner-password"
  },
  "team-member": {
    "email": "team-member@example.com",
    "password": "replace-with-team-member-password"
  },
  "system-admin": {
    "email": "system-admin@example.com",
    "password": "replace-with-system-admin-password"
  },
  "review-admin": {
    "email": "review-admin@example.com",
    "password": "replace-with-review-admin-password"
  },
  "review-member": {
    "email": "review-member@example.com",
    "password": "replace-with-review-member-password"
  }
}'

# Option B: provide credentials per role.
# TEST_USER_EMAIL=user@example.com
# TEST_USER_PASSWORD=replace-with-user-password

# TEST_ADMIN_EMAIL=admin@example.com
# TEST_ADMIN_PASSWORD=replace-with-admin-password

# TEST_TEAM_OWNER_EMAIL=team-owner@example.com
# TEST_TEAM_OWNER_PASSWORD=replace-with-team-owner-password

# TEST_TEAM_MEMBER_EMAIL=team-member@example.com
# TEST_TEAM_MEMBER_PASSWORD=replace-with-team-member-password

# TEST_SYSTEM_ADMIN_EMAIL=system-admin@example.com
# TEST_SYSTEM_ADMIN_PASSWORD=replace-with-system-admin-password

# TEST_REVIEW_ADMIN_EMAIL=review-admin@example.com
# TEST_REVIEW_ADMIN_PASSWORD=replace-with-review-admin-password

# TEST_REVIEW_MEMBER_EMAIL=review-member@example.com
# TEST_REVIEW_MEMBER_PASSWORD=replace-with-review-member-password
